# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# Auth
AUTH_SECRET=replace-with-a-long-random-secret
PORTAL_SESSION_SECRET=replace-with-a-long-random-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tac_xpress
SUPABASE_POOLER_URL=postgresql://postgres.projectid:password@aws-0-region.pooler.supabase.com:6543/postgres

# Security and edge protection
ARCJET_KEY=your-arcjet-key
CRON_SECRET=replace-with-a-long-random-secret
MOBILE_API_SECRET=replace-with-a-long-random-secret
PHONE_HASH_SECRET=replace-with-a-long-random-secret
INVOICE_PDF_SIGNING_SECRET=replace-with-a-long-random-secret

# AI
OPENROUTER_API=your-openrouter-api-key
OPENAI_MODEL=gpt-4o-mini
AI_AUTO_REPLY_ENABLED=false

# Email
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=support@tac-xpress.app
OPS_NOTIFICATION_EMAIL=operations@tac-xpress.app

# Mapping and analytics
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
POSTHOG_KEY=
POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# WhatsApp and carrier integrations
WHATSAPP_ENABLED=false
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WPBOX_API_TOKEN=
WPBOX_USER_ID=
WPBOX_BASE_URL=https://chat.leminai.com
CARRIER_WEBHOOK_SECRET=replace-with-a-long-random-secret
RESEND_FROM_EMAIL=Tac-Xpress <updates@tac-xpress.app>

# E2E
E2E_TEST_BYPASS_ENABLED=false
NEXT_PUBLIC_E2E_TEST_BYPASS_ENABLED=false
E2E_TEST_SECRET=replace-with-a-long-random-secret
E2E_TEST_USER_PASSWORD=replace-with-a-strong-password
E2E_TEST_EMAIL=admin@test.tacexpress.app
PLAYWRIGHT_TEST=false
TEST_SPRITE_SESSION=

# Monitoring and optional diagnostics
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_REPLAY_ENABLED=false
NEXT_PUBLIC_SYSTEM_BANNER=
ANALYZE=false

# Sentry source maps / release tracking (set in CI / Vercel env)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
SENTRY_AUTH_TOKEN=

# Vercel Blob Storage
NEXT_PUBLIC_VERCEL_BLOB_HOSTNAME=your-project.public.blob.vercel-storage.com
