{
  "name": "tac-xpress",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "design:lint": "designmd lint docs/DESIGN.md",
    "design:diff": "designmd diff docs/DESIGN.md docs/DESIGN-v2.md",
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "build:safe": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "eslint",
    "stylelint": "stylelint \"**/*.css\"",
    "stylelint:fix": "stylelint \"**/*.css\" --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:a11y": "playwright test --pass-with-no-tests",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "audit:usage": "npx tsx scripts/audit-component-usage.ts",
    "generate:contracts": "npx tsx scripts/generate-api-contract.ts",
    "validate:contracts": "redocly lint contracts/cargo-api.json",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "db:seed": "npx tsx --env-file=.env.local scripts/seed-demo-data.ts",
    "db:sync": "npx tsx --env-file=.env.local scripts/sync-schema.ts",
    "db:types": "supabase gen types typescript --local > types/supabase.ts",
    "gbrain:init": "gbrain init --pglite",
    "gbrain:sync": "gbrain sync",
    "gbrain:serve": "gbrain serve",
    "gbrain:think": "gbrain think",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
